# Auto normalize line endings for all text files
* text=auto

# Normalize to LF for shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Normalize to LF for JavaScript/JSON
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
